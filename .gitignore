# Ignore everything
*

# Allow .gitignore itself
!.gitignore

# Track only these three
!README.md
!server/
!server/**
!B1_Platform/
!B1_Platform/**
!docs/
!docs/**

# Allow deploy artifacts (root-level, otherwise swallowed by the leading *)
!docker-compose.yml
!docker-compose.prod.yml
!.env.example
!deploy/
!deploy/**

# Exclude build outputs (must come after the !server/** whitelist to take effect)
server/target/**
server/target/
server/BOOT-INF/**
server/BOOT-INF/

# Exclude secrets (local-only config, never commit)
server/src/main/resources/application-local.yml

# Exclude runtime logs
server/*.log
server/**/*.log
B1_Platform/dev.log

# Exclude real secrets (only the .env.example template is tracked)
.env

